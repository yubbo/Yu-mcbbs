# ────────────────────────────────────
# BBS CMS Docker 部署环境变量
# 复制本文件为 .env.docker 并修改
# ────────────────────────────────────

# 数据库（务必修改 root 密码和用户密码）
DB_ROOT_PASSWORD=root-secret-change-me
DB_USER=bbs_cms
DB_PASSWORD=bbs-cms-pwd
DB_NAME=bbs_cms
# DB_EXPOSE_PORT=3306    # 数据库暴露端口，默认 3306

# JWT 密钥（务必改为随机字符串！）
JWT_SECRET=change-me-in-production-please

# 日志级别：debug / info / warn / error
LOG_LEVEL=info

# CORS 跨域（云服务器部署时改为实际域名）
# CORS_ALLOW_ORIGINS=https://your-domain.com,http://localhost:3000

# 端口（可选）
# BACKEND_PORT=8080
# FRONTEND_PORT=3000
